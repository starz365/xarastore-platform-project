/* =========================================================
   TYPES
========================================================= */

export interface Category {
  id: string;
  label: string;
  href?: string;
  icon?: React.ReactNode;
  children?: Category[];
  featured?: boolean;
  analyticsKey?: string;
}

export interface MegaMenuProps {
  dataEndpoint?: string;
  staticData?: Category[];
  onNavigate?: (href: string) => void;
  enablePrefetch?: boolean;
}

/* =========================================================
   UTILITIES
========================================================= */

function debounce(fn: Function, delay: number) {
  let t: any;
  return (...args: any[]) => {
    clearTimeout(t);
    t = setTimeout(() => fn(...args), delay);
  };
}

function clamp(num: number, min: number, max: number) {
  return Math.min(Math.max(num, min), max);
}

/* =========================================================
   ANALYTICS
========================================================= */

export const analytics = {
  track(event: string, payload: any) {
    if (typeof window === "undefined") return;
    console.debug("NAV_EVENT", event, payload);
  }
};

/* =========================================================
   DATA LOADER
========================================================= */

async function fetchNavigationData(endpoint: string): Promise<Category[]> {
  const res = await fetch(endpoint, { credentials: "include" });
  if (!res.ok) throw new Error("Navigation fetch failed");
  return res.json();
}

/* =========================================================
   HOVER INTENT ENGINE
========================================================= */

function useHoverIntent(delay = 120) {
  const [active, setActive] = useState<string | null>(null);
  const timeout = useRef<any>(null);

  const enter = (id: string) => {
    clearTimeout(timeout.current);
    timeout.current = setTimeout(() => setActive(id), delay);
  };

  const leave = () => {
    clearTimeout(timeout.current);
    timeout.current = setTimeout(() => setActive(null), delay);
  };

  return { active, enter, leave };
}

/* =========================================================
   PREFETCH ENGINE
========================================================= */

function prefetch(url: string) {
  if (typeof window === "undefined") return;

  const link = document.createElement("link");
  link.rel = "prefetch";
  link.href = url;

  document.head.appendChild(link);
}

/* =========================================================
   VIEWPORT DETECTION
========================================================= */

function useBreakpoint() {
  const [mobile, setMobile] = useState(false);

  useEffect(() => {
    const check = () => setMobile(window.innerWidth < 900);

    check();
    window.addEventListener("resize", check);

    return () => window.removeEventListener("resize", check);
  }, []);

  return mobile;
}

/* =========================================================
   VIRTUALIZED LIST
========================================================= */

function VirtualList({ items }: { items: Category[] }) {
  const container = useRef<HTMLDivElement>(null);

  const [range, setRange] = useState([0, 20]);

  const onScroll = () => {
    if (!container.current) return;

    const top = container.current.scrollTop;

    const start = Math.floor(top / 40);

    setRange([start, start + 30]);
  };

  const visible = items.slice(range[0], range[1]);

  return (
    <div
      ref={container}
      onScroll={onScroll}
      style={{ height: 400, overflow: "auto" }}
    >
      {visible.map(c => (
        <div key={c.id}>{c.label}</div>
      ))}
    </div>
  );
}

/* =========================================================
   KEYBOARD NAVIGATION
========================================================= */

function useKeyboardNavigation(ids: string[]) {
  const [index, setIndex] = useState(0);

  const onKeyDown = (e: React.KeyboardEvent) => {
    if (e.key === "ArrowDown") {
      setIndex(i => clamp(i + 1, 0, ids.length - 1));
    }

    if (e.key === "ArrowUp") {
      setIndex(i => clamp(i - 1, 0, ids.length - 1));
    }
  };

  return { index, onKeyDown };
}

/* =========================================================
   MENU COLUMN
========================================================= */

function MenuColumn({ items }: { items: Category[] }) {
  return (
    <div style={{ padding: 16, minWidth: 200 }}>
      {items.map(item => (
        <a
          key={item.id}
          href={item.href}
          style={{
            display: "block",
            padding: "8px 0",
            color: tokens.color.text,
            textDecoration: "none"
          }}
        >
          {item.label}
        </a>
      ))}
    </div>
  );
}

/* =========================================================
   MEGA PANEL
========================================================= */

function MegaPanel({ category }: { category: Category }) {
  if (!category.children) return null;

  const columns: Category[][] = [];

  const size = 8;

  for (let i = 0; i < category.children.length; i += size) {
    columns.push(category.children.slice(i, i + size));
  }

  return (
    <div
      style={{
        position: "absolute",
        left: 0,
        top: "100%",
        display: "flex",
        background: tokens.color.bg,
        boxShadow: tokens.shadow.menu,
        borderRadius: tokens.radius.md,
        border: `1px solid ${tokens.color.border}`,
        padding: tokens.spacing.lg,
        zIndex: 1000
      }}
    >
      {columns.map((col, i) => (
        <MenuColumn key={i} items={col} />
      ))}
    </div>
  );
}

/* =========================================================
   NAV ITEM
========================================================= */

function NavItem({
  item,
  active,
  onEnter,
  onLeave
}: {
  item: Category;
  active: boolean;
  onEnter: () => void;
  onLeave: () => void;
}) {
  return (
    <div
      onMouseEnter={onEnter}
      onMouseLeave={onLeave}
      style={{
        position: "relative",
        padding: "12px 16px",
        cursor: "pointer"
      }}
    >
      {item.label}

      {active && <MegaPanel category={item} />}
    </div>
  );
}

/* =========================================================
   MOBILE NAV
========================================================= */

function MobileNav({ data }: { data: Category[] }) {
  const [open, setOpen] = useState<string | null>(null);

  return (
    <div>
      {data.map(cat => (
        <div key={cat.id}>
          <div
            onClick={() => setOpen(o => (o === cat.id ? null : cat.id))}
            style={{ padding: 16, borderBottom: "1px solid #eee" }}
          >
            {cat.label}
          </div>

          {open === cat.id && cat.children && (
            <div style={{ paddingLeft: 16 }}>
              {cat.children.map(c => (
                <div key={c.id}>{c.label}</div>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  );
}

/* =========================================================
   PREDICTIVE ADAPTIVE ENGINE
========================================================= */

function useAdaptiveOrdering(categories: Category[]) {
  const [ordered, setOrdered] = useState(categories);

  useEffect(() => {
    const stats = JSON.parse(localStorage.getItem("navStats") || "{}");

    const sorted = [...categories].sort((a, b) => {
      return (stats[b.id] || 0) - (stats[a.id] || 0);
    });

    setOrdered(sorted);
  }, [categories]);

  return ordered;
}

function recordClick(id: string) {
  const stats = JSON.parse(localStorage.getItem("navStats") || "{}");

  stats[id] = (stats[id] || 0) + 1;

  localStorage.setItem("navStats", JSON.stringify(stats));
}

/* =========================================================
   MAIN COMPONENT
========================================================= */

export default function AdaptiveMegaNavigation({
  dataEndpoint,
  staticData,
  onNavigate,
  enablePrefetch = true
}: MegaMenuProps) {
  const [data, setData] = useState<Category[]>(staticData || []);

  const mobile = useBreakpoint();

  const hover = useHoverIntent();

  useEffect(() => {
    if (!dataEndpoint) return;

    fetchNavigationData(dataEndpoint)
      .then(setData)
      .catch(console.error);
  }, [dataEndpoint]);

  const ordered = useAdaptiveOrdering(data);

  const navigate = (href?: string, id?: string) => {
    if (!href) return;

    recordClick(id || "unknown");

    analytics.track("navigate", { href });

    if (onNavigate) onNavigate(href);
    else window.location.href = href;
  };

  if (mobile) return <MobileNav data={ordered} />;

  return (
    <nav
      style={{
        display: "flex",
        borderBottom: `1px solid ${tokens.color.border}`,
        background: tokens.color.bg
      }}
    >
      {ordered.map(cat => (
        <NavItem
          key={cat.id}
          item={cat}
          active={hover.active === cat.id}
          onEnter={() => {
            hover.enter(cat.id);

            if (enablePrefetch && cat.href) prefetch(cat.href);
          }}
          onLeave={hover.leave}
        />
      ))}
    </nav>
  );
}

/* =========================================================
   PLUGIN SYSTEM
========================================================= */

export interface NavPlugin {
  name: string;
  init?: () => void;
  transform?: (data: Category[]) => Category[];
}

export function applyPlugins(data: Category[], plugins: NavPlugin[]) {
  return plugins.reduce((d, p) => {
    if (p.transform) return p.transform(d);
    return d;
  }, data);
}

/* =========================================================
   OBSERVER FOR REALTIME CMS UPDATES
========================================================= */

export function useRealtimeNavigation(endpoint: string) {
  const [data, setData] = useState<Category[]>([]);

  useEffect(() => {
    let active = true;

    async function load() {
      const d = await fetchNavigationData(endpoint);
      if (active) setData(d);
    }

    load();

    const interval = setInterval(load, 30000);

    return () => {
      active = false;
      clearInterval(interval);
    };
  }, [endpoint]);

  return data;
}

/* =========================================================
   FEATURED PROMOTION PANEL
========================================================= */

export function FeaturedPanel({ items }: { items: Category[] }) {
  const featured = items.filter(i => i.featured);

  if (!featured.length) return null;

  return (
    <div
      style={{
        padding: 24,
        borderLeft: `1px solid ${tokens.color.border}`
      }}
    >
      {featured.map(f => (
        <div key={f.id}>{f.label}</div>
      ))}
    </div>
  );
}

