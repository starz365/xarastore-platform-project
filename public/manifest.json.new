{
  "name": "Xarastore - It's a Deal",
  "short_name": "Xarastore",
  "description": "Kenya's premier online marketplace. Shop electronics, fashion, home goods, and more with exclusive deals and secure payments.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "minimal-ui", "standalone"],
  "background_color": "#ffffff",
  "theme_color": "#dc2626",
  "orientation": "portrait-primary",
  "categories": ["shopping", "ecommerce", "retail", "marketplace"],
  "lang": "en-KE",
  "dir": "ltr",
  "prefer_related_applications": false,
  "id": "com.xarastore.app",
  "edge_side_panel": {
    "preferred_width": 400
  },
  "screenshots": [
    {
      "src": "/images/screenshots/home.webp",
      "sizes": "1080x1920",
      "type": "image/webp",
      "platform": "wide",
      "label": "Xarastore Homepage - Browse amazing deals"
    },
    {
      "src": "/images/screenshots/product.webp",
      "sizes": "1080x1920",
      "type": "image/webp",
      "platform": "wide",
      "label": "Product Details - View specifications and reviews"
    },
    {
      "src": "/images/screenshots/cart.webp",
      "sizes": "1080x1920",
      "type": "image/webp",
      "platform": "wide",
      "label": "Shopping Cart - Review your items"
    },
    {
      "src": "/images/screenshots/checkout.webp",
      "sizes": "1080x1920",
      "type": "image/webp",
      "platform": "wide",
      "label": "Secure Checkout with M-Pesa integration"
    }
  ],
  "icons": [
    {
