/**
 * Search collections by name or description
 * @param query Search query
 * @param limit Maximum number of results to return
 */
export async function searchCollections(
  query: string,
  limit: number = 10
): Promise<Collection[]> {
  try {
    if (!query.trim()) {
      return [];
    }

    const { data, error } = await fetchWithTimeout(
      supabase
        .from('collections')
        .select('*')
        .eq('is_active', true)
        .or(`name.ilike.%${query}%,description.ilike.%${query}%`)
        .order('updated_at', { ascending: false })
        .limit(limit)
    );

    if (error) {
      logger.error('Error searching collections:', error);
      return [];
    }

    return (data || []).map(transformCollection);
  } catch (error) {
    if (error instanceof Error && error.name === 'AbortError') {
      return [];
    }
    logger.error('Error searching collections:', error);
    return [];
  }
}

/**
 * Check if a collection exists and is active
 * @param slug Collection slug
 */
export async function collectionExists(slug: string): Promise<boolean> {
  try {
    const { count, error } = await fetchWithTimeout(
      supabase
        .from('collections')
        .select('*', { count: 'exact', head: true })
        .eq('slug', slug)
        .eq('is_active', true)
    );

    if (error) {
      logger.error(`Error checking if collection exists "${slug}":`, error);
      return false;
    }

    return (count || 0) > 0;
  } catch (error) {
    if (error instanceof Error && error.name === 'AbortError') {
      return false;
    }
    logger.error(`Error checking if collection exists "${slug}":`, error);
    return false;
  }
}

/**
 * Get similar collections (same type)
 * @param collectionId Current collection ID
 * @param limit Maximum number of similar collections to return
 */
export async function getSimilarCollections(
  collectionId: string,
  limit: number = 4
): Promise<Collection[]> {
  try {
    // First, get the current collection
    const { data: currentCollection, error: collectionError } = await fetchWithTimeout(
      supabase
        .from('collections')
        .select('type')
        .eq('id', collectionId)
        .single()
    );

    if (collectionError || !currentCollection) {
      return [];
    }

    // If type column doesn't exist or type is null, return recent collections
    if (!currentCollection.type) {
      const { data: recentData } = await fetchWithTimeout(
        supabase
          .from('collections')
          .select('*')
          .neq('id', collectionId)
          .eq('is_active', true)
          .order('updated_at', { ascending: false })
          .limit(limit)
      );
      return (recentData || []).map(transformCollection);
    }

    // Find collections with the same type, excluding the current one
    const { data, error } = await fetchWithTimeout(
      supabase
        .from('collections')
        .select('*')
        .eq('type', currentCollection.type)
        .neq('id', collectionId)
        .eq('is_active', true)
        .order('updated_at', { ascending: false })
        .limit(limit)
    );

    if (error) {
      // If error is about missing column, return recent collections
      if (error.message?.includes('column collections.type does not exist')) {
        const { data: recentData } = await fetchWithTimeout(
          supabase
            .from('collections')
            .select('*')
            .neq('id', collectionId)
            .eq('is_active', true)
            .order('updated_at', { ascending: false })
            .limit(limit)
        );
        return (recentData || []).map(transformCollection);
      }
      logger.error(`Error fetching similar collections for "${collectionId}":`, error);
      return [];
    }

    // If we don't have enough same-type collections, fill with recent ones
    if ((data?.length || 0) < limit) {
      const remaining = limit - (data?.length || 0);
      const { data: recentData } = await fetchWithTimeout(
        supabase
          .from('collections')
          .select('*')
          .neq('id', collectionId)
          .eq('is_active', true)
          .order('updated_at', { ascending: false })
          .limit(remaining)
      );

      const allCollections = [
        ...(data || []),
        ...(recentData || []),
      ].slice(0, limit);

      return allCollections.map(transformCollection);
    }

    return (data || []).map(transformCollection);
  } catch (error) {
    if (error instanceof Error && error.name === 'AbortError') {
      return [];
    }
    logger.error(`Error fetching similar collections for "${collectionId}":`, error);
    return [];
  }
}
