}

/**
 * Get collection types with counts
 * Returns all collection types with the number of active collections in each
 */
export async function getCollectionTypesWithCounts(): Promise<Array<{
  type: string;
  count: number;
}>> {
  try {
    // First check if type column exists by trying to select it
    const { data: testData, error: testError } = await supabase
      .from('collections')
      .select('type')
      .limit(1);

    // If there's an error about the column not existing, return mock data
    if (testError && testError.message?.includes('column collections.type does not exist')) {
      return MOCK_COLLECTION_TYPES;
    }

    // If column exists, proceed with actual query
    const { data, error } = await fetchWithTimeout(
      supabase
        .from('collections')
        .select('type, id')
        .eq('is_active', true)
    );

    if (error) {
      logger.error('Error fetching collection types with counts:', error);
      return MOCK_COLLECTION_TYPES;
    }

    // Group by type and count in JavaScript
    const typeCounts = (data || []).reduce((acc: Record<string, number>, item) => {
      const type = item.type || 'uncategorized';
      if (!acc[type]) {
        acc[type] = 0;
      }
      acc[type]++;
      return acc;
    }, {});

    // Convert to array format
    return Object.entries(typeCounts).map(([type, count]) => ({
      type,
      count: count as number,
    }));
  } catch (error) {
    if (error instanceof Error && error.name === 'AbortError') {
      return MOCK_COLLECTION_TYPES;
    }
    logger.error('Error fetching collection types with counts:', error);
    return MOCK_COLLECTION_TYPES;
  }
}

