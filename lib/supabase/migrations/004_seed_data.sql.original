END $$;

-- Update product counts in categories based on sample data
-- Note: In production, these would be updated via triggers when products are added
UPDATE categories SET product_count = CASE slug
    WHEN 'electronics' THEN 1250
    WHEN 'smartphones' THEN 350
    WHEN 'laptops' THEN 280
    WHEN 'audio' THEN 420
    WHEN 'fashion' THEN 1560
    WHEN 'mens-fashion' THEN 720
    WHEN 'womens-fashion' THEN 840
    WHEN 'shoes' THEN 450
    WHEN 'home-living' THEN 980
    WHEN 'kitchen' THEN 520
    WHEN 'furniture' THEN 460
    WHEN 'beauty-health' THEN 630
    WHEN 'skincare' THEN 290
    WHEN 'makeup' THEN 340
    WHEN 'sports-outdoors' THEN 380
    WHEN 'fitness' THEN 210
    WHEN 'outdoor' THEN 170
    WHEN 'automotive' THEN 290
    WHEN 'car-accessories' THEN 290
    WHEN 'groceries' THEN 1120
    WHEN 'beverages' THEN 430
    WHEN 'books-stationery' THEN 310
    WHEN 'toys-games' THEN 240
    ELSE 0
END;

-- Update brand product counts
