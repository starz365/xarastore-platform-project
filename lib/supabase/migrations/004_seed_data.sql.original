UPDATE categories SET parent_id = 'ffffffff-ffff-ffff-ffff-ffffffffffff' WHERE slug IN ('fitness', 'outdoor');
UPDATE categories SET parent_id = '34567890-3456-3456-3456-345678901234' WHERE slug = 'car-accessories';
UPDATE categories SET parent_id = '56789012-5678-5678-5678-567890123456' WHERE slug = 'beverages';

