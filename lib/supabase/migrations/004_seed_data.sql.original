    WHEN 'estee-lauder' THEN 90
    WHEN 'kingsway' THEN 75
    WHEN 'nakumatt' THEN 420
    WHEN 'safaricom' THEN 35
    WHEN 'puma' THEN 110
    WHEN 'under-armour' THEN 85
    WHEN 'bosch' THEN 70
    WHEN 'michelin' THEN 45
