-- Insert default email templates
INSERT INTO email_templates (id, name, subject, body, variables, is_active) VALUES
-- Order confirmation
('11111111-1111-1111-1111-111111111111', 'order_confirmation', 'Order Confirmation - {{order_number}}',
'<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Confirmation</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background-color: #dc2626; color: white; padding: 20px; text-align: center; border-radius: 5px 5px 0 0; }
        .content { background-color: #f9f9f9; padding: 20px; border-radius: 0 0 5px 5px; }
        .order-details { background: white; padding: 15px; border-radius: 5px; margin: 15px 0; }
        .footer { text-align: center; margin-top: 20px; color: #666; font-size: 12px; }
        .button { display: inline-block; background-color: #dc2626; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; margin: 10px 0; }
    </style>
</head>
<body>
    <div class="header">
        <h1>Thank You for Your Order!</h1>
    </div>
    <div class="content">
        <p>Hello {{customer_name}},</p>
        <p>Your order has been confirmed and is being processed. Here are your order details:</p>
        
        <div class="order-details">
            <h3>Order #{{order_number}}</h3>
            <p><strong>Order Date:</strong> {{order_date}}</p>
            <p><strong>Total Amount:</strong> {{order_total}}</p>
            <p><strong>Payment Method:</strong> {{payment_method}}</p>
            <p><strong>Shipping Address:</strong><br>{{shipping_address}}</p>
        </div>
        
        <h3>Order Items:</h3>
        {{order_items}}
        
        <p>You can track your order status anytime from your account.</p>
        
        <a href="{{tracking_link}}" class="button">Track Your Order</a>
        
        <p>If you have any questions, please contact our support team at {{support_email}}.</p>
        
        <p>Thank you for shopping with Xarastore!</p>
    </div>
    <div class="footer">
        <p>Xarastore - it''s a deal</p>
        <p>{{store_address}}</p>
        <p>© {{current_year}} Xarastore. All rights reserved.</p>
    </div>
</body>
</html>',
'["customer_name", "order_number", "order_date", "order_total", "payment_method", "shipping_address", "order_items", "tracking_link", "support_email", "store_address", "current_year"]',
true),

-- Shipping confirmation
('22222222-2222-2222-2222-222222222222', 'shipping_confirmation', 'Your Order Has Shipped! - {{order_number}}',
'<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Shipped</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background-color: #dc2626; color: white; padding: 20px; text-align: center; border-radius: 5px 5px 0 0; }
        .content { background-color: #f9f9f9; padding: 20px; border-radius: 0 0 5px 5px; }
        .tracking-info { background: white; padding: 15px; border-radius: 5px; margin: 15px 0; }
        .footer { text-align: center; margin-top: 20px; color: #666; font-size: 12px; }
        .button { display: inline-block; background-color: #dc2626; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; margin: 10px 0; }
    </style>
</head>
<body>
    <div class="header">
        <h1>Your Order is on the Way!</h1>
    </div>
    <div class="content">
        <p>Hello {{customer_name}},</p>
        <p>Great news! Your order has been shipped and is on its way to you.</p>
        
        <div class="tracking-info">
            <h3>Tracking Information</h3>
            <p><strong>Order Number:</strong> {{order_number}}</p>
            <p><strong>Tracking Number:</strong> {{tracking_number}}</p>
            <p><strong>Carrier:</strong> {{carrier}}</p>
            <p><strong>Estimated Delivery:</strong> {{estimated_delivery}}</p>
        </div>
        
        <a href="{{tracking_link}}" class="button">Track Your Package</a>
        
        <p>You can track your shipment using the tracking number above on the carrier''s website.</p>
        
        <p>If you have any questions about your delivery, please contact our support team.</p>
        
        <p>Thank you for shopping with Xarastore!</p>
    </div>
    <div class="footer">
        <p>Xarastore - it''s a deal</p>
        <p>{{store_address}}</p>
        <p>© {{current_year}} Xarastore. All rights reserved.</p>
    </div>
</body>
</html>',
'["customer_name", "order_number", "tracking_number", "carrier", "estimated_delivery", "tracking_link", "store_address", "current_year"]',
true),

-- Password reset
('33333333-3333-3333-3333-333333333333', 'password_reset', 'Reset Your Password',
'<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background-color: #dc2626; color: white; padding: 20px; text-align: center; border-radius: 5px 5px 0 0; }
        .content { background-color: #f9f9f9; padding: 20px; border-radius: 0 0 5px 5px; }
        .footer { text-align: center; margin-top: 20px; color: #666; font-size: 12px; }
        .button { display: inline-block; background-color: #dc2626; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; margin: 10px 0; }
        .note { background: #fff3cd; border: 1px solid #ffecb5; padding: 10px; border-radius: 5px; margin: 15px 0; }
    </style>
</head>
<body>
    <div class="header">
        <h1>Password Reset Request</h1>
    </div>
    <div class="content">
        <p>Hello,</p>
        <p>We received a request to reset your password for your Xarastore account.</p>
        
        <a href="{{reset_link}}" class="button">Reset Password</a>
        
        <div class="note">
            <p><strong>Note:</strong> This password reset link will expire in 1 hour.</p>
            <p>If you did not request a password reset, please ignore this email or contact support if you have concerns.</p>
        </div>
        
        <p>For security reasons, we recommend that you:</p>
        <ul>
            <li>Use a strong password that you don''t use elsewhere</li>
            <li>Enable two-factor authentication if available</li>
            <li>Regularly update your password</li>
        </ul>
        
        <p>If you need further assistance, please contact our support team at {{support_email}}.</p>
    </div>
    <div class="footer">
        <p>Xarastore - it''s a deal</p>
        <p>{{store_address}}</p>
        <p>© {{current_year}} Xarastore. All rights reserved.</p>
    </div>
</body>
</html>',
'["reset_link", "support_email", "store_address", "current_year"]',
true),

-- Welcome email
('44444444-4444-4444-4444-444444444444', 'welcome_email', 'Welcome to Xarastore!',
'<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome to Xarastore</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background-color: #dc2626; color: white; padding: 20px; text-align: center; border-radius: 5px 5px 0 0; }
        .content { background-color: #f9f9f9; padding: 20px; border-radius: 0 0 5px 5px; }
        .footer { text-align: center; margin-top: 20px; color: #666; font-size: 12px; }
        .button { display: inline-block; background-color: #dc2626; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; margin: 10px 0; }
        .benefits { background: white; padding: 15px; border-radius: 5px; margin: 15px 0; }
    </style>
</head>
<body>
    <div class="header">
        <h1>Welcome to Xarastore!</h1>
    </div>
    <div class="content">
        <p>Hello {{customer_name}},</p>
        <p>Welcome to Xarastore - where it''s always a deal! We''re excited to have you join our community of smart shoppers.</p>
        
        <div class="benefits">
            <h3>Get Started with These Benefits:</h3>
            <ul>
                <li><strong>Exclusive Deals:</strong> Access members-only discounts and flash sales</li>
                <li><strong>Fast Delivery:</strong> Enjoy quick shipping across Kenya</li>
                <li><strong>Easy Returns:</strong> 30-day hassle-free return policy</li>
                <li><strong>Secure Payments:</strong> Multiple safe payment options including M-Pesa</li>
                <li><strong>Wishlist:</strong> Save items for later and get price drop alerts</li>
            </ul>
        </div>
        
        <a href="{{store_link}}" class="button">Start Shopping Now</a>
        
        <p>To get the most out of your account:</p>
        <ol>
            <li>Complete your profile information</li>
            <li>Add your delivery addresses</li>
            <li>Enable notifications for deals</li>
            <li>Follow us on social media for updates</li>
        </ol>
        
        <p>Need help? Our support team is available 24/7 at {{support_email}} or call us at {{support_phone}}.</p>
        
        <p>Happy shopping!</p>
        <p>The Xarastore Team</p>
    </div>
    <div class="footer">
        <p>Xarastore - it''s a deal</p>
        <p>{{store_address}}</p>
        <p>© {{current_year}} Xarastore. All rights reserved.</p>
    </div>
</body>
</html>',
'["customer_name", "store_link", "support_email", "support_phone", "store_address", "current_year"]',
true),

-- Abandoned cart reminder
('55555555-5555-5555-5555-555555555555', 'abandoned_cart', 'Complete Your Purchase - Items Waiting!',
'<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Complete Your Purchase</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background-color: #dc2626; color: white; padding: 20px; text-align: center; border-radius: 5px 5px 0 0; }
        .content { background-color: #f9f9f9; padding: 20px; border-radius: 0 0 5px 5px; }
        .cart-items { background: white; padding: 15px; border-radius: 5px; margin: 15px 0; }
        .footer { text-align: center; margin-top: 20px; color: #666; font-size: 12px; }
        .button { display: inline-block; background-color: #dc2626; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; margin: 10px 0; }
        .offer { background: #d4edda; border: 1px solid #c3e6cb; padding: 10px; border-radius: 5px; margin: 15px 0; }
    </style>
</head>
<body>
    <div class="header">
        <h1>Don''t Miss Out!</h1>
    </div>
    <div class="content">
        <p>Hello {{customer_name}},</p>
        <p>We noticed you left some items in your cart. They''re waiting for you!</p>
        
        <div class="cart-items">
            <h3>Your Cart Items:</h3>
            {{cart_items}}
            <p><strong>Cart Total:</strong> {{cart_total}}</p>
        </div>
        
        <div class="offer">
            <p><strong>Special Offer:</strong> Complete your purchase within 24 hours and get free shipping!</p>
        </div>
        
        <a href="{{cart_link}}" class="button">Complete Your Purchase</a>
        
        <p>Why shop with Xarastore?</p>
        <ul>
            <li>✓ Secure checkout with multiple payment options</li>
            <li>✓ Fast delivery across Kenya</li>
            <li>✓ Easy returns within 30 days</li>
            <li>✓ 24/7 customer support</li>
        </ul>
        
        <p>If you need any help with your purchase, reply to this email or call us at {{support_phone}}.</p>
        
        <p>Happy shopping!</p>
    </div>
    <div class="footer">
        <p>Xarastore - it''s a deal</p>
        <p>{{store_address}}</p>
        <p>© {{current_year}} Xarastore. All rights reserved.</p>
    </div>
</body>
</html>',
'["customer_name", "cart_items", "cart_total", "cart_link", "support_phone", "store_address", "current_year"]',
true)
ON CONFLICT (name) DO UPDATE SET
    subject = EXCLUDED.subject,
    body = EXCLUDED.body,
    variables = EXCLUDED.variables,
    is_active = EXCLUDED.is_active;

