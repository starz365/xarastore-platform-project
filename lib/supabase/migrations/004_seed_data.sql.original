-- Update parent-child relationships
UPDATE categories SET parent_id = '11111111-1111-1111-1111-111111111111' WHERE slug IN ('smartphones', 'laptops', 'audio');
UPDATE categories SET parent_id = '55555555-5555-5555-5555-555555555555' WHERE slug IN ('mens-fashion', 'womens-fashion', 'shoes');
