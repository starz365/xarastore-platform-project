INSERT INTO products (id, slug, name, description, price, compare_at_price, cost, category_id, brand_id, sku, barcode, stock_quantity, low_stock_threshold, images, is_active, is_featured, rating, review_count, tags, meta_title, meta_description) VALUES

-- Smartphones
('p1111111-1111-1111-1111-111111111111', 'iphone-15-pro-max-256gb', 'iPhone 15 Pro Max 256GB', 'Latest iPhone with A17 Pro chip, titanium design, and advanced camera system. Features 6.7-inch Super Retina XDR display, ProMotion technology, and all-day battery life.', 189999, 199999, 145000, '22222222-2222-2222-2222-222222222222', '11111111-1111-1111-1111-111111111111', 'APL-IP15PM-256', '194253149514', 45, 10, '["https://cdn.xarastore.com/products/iphone-15-pro-max-1.jpg", "https://cdn.xarastore.com/products/iphone-15-pro-max-2.jpg", "https://cdn.xarastore.com/products/iphone-15-pro-max-3.jpg", "https://cdn.xarastore.com/products/iphone-15-pro-max-4.jpg"]', true, true, 4.8, 156, '["smartphone", "apple", "iphone", "5g", "flagship"]', 'iPhone 15 Pro Max 256GB - Buy Online at Best Price | Xarastore', 'Get the latest iPhone 15 Pro Max with 256GB storage. Features A17 Pro chip, titanium design, and professional camera system. Free delivery in Nairobi.'),

('p1111112-1111-1111-1111-111111111111', 'samsung-galaxy-s24-ultra', 'Samsung Galaxy S24 Ultra 512GB', 'Premium Samsung flagship with S Pen, 200MP camera, and AI features. 6.8-inch Dynamic AMOLED display with 120Hz refresh rate.', 164999, 174999, 125000, '22222222-2222-2222-2222-222222222222', '22222222-2222-2222-2222-222222222222', 'SAM-S24U-512', '887276794822', 38, 10, '["https://cdn.xarastore.com/products/galaxy-s24-ultra-1.jpg", "https://cdn.xarastore.com/products/galaxy-s24-ultra-2.jpg", "https://cdn.xarastore.com/products/galaxy-s24-ultra-3.jpg"]', true, true, 4.7, 142, '["smartphone", "samsung", "android", "5g", "s-pen"]', 'Samsung Galaxy S24 Ultra 512GB - Latest Flagship | Xarastore', 'Samsung Galaxy S24 Ultra with 512GB storage, S Pen, and 200MP camera. Experience Galaxy AI and premium performance.'),

('p1111113-1111-1111-1111-111111111111', 'google-pixel-8-pro', 'Google Pixel 8 Pro 256GB', 'Google''s flagship phone with AI-powered photography and pure Android experience. Features Tensor G3 chip and 6.7-inch LTPO OLED display.', 124999, 134999, 95000, '22222222-2222-2222-2222-222222222222', '22222222-2222-2222-2222-222222222222', 'GOO-PIX8P-256', '840244702359', 28, 10, '["https://cdn.xarastore.com/products/pixel-8-pro-1.jpg", "https://cdn.xarastore.com/products/pixel-8-pro-2.jpg"]', true, true, 4.6, 89, '["smartphone", "google", "pixel", "android", "ai-camera"]', 'Google Pixel 8 Pro 256GB - AI Photography | Xarastore', 'Get the Google Pixel 8 Pro with advanced AI features and the best Android camera. Pure Android experience with 7 years of updates.'),

('p1111114-1111-1111-1111-111111111111', 'xiaomi-14-ultra', 'Xiaomi 14 Ultra 512GB', 'Photography powerhouse with Leica optics and Snapdragon 8 Gen 3. Features 6.73-inch AMOLED display and 5000mAh battery with 90W charging.', 109999, 119999, 85000, '22222222-2222-2222-2222-222222222222', '22222222-2222-2222-2222-222222222222', 'XIA-14U-512', '6941812761953', 32, 10, '["https://cdn.xarastore.com/products/xiaomi-14-ultra-1.jpg", "https://cdn.xarastore.com/products/xiaomi-14-ultra-2.jpg"]', true, false, 4.5, 67, '["smartphone", "xiaomi", "leica", "photography", "flagship"]', 'Xiaomi 14 Ultra 512GB - Leica Camera System | Xarastore', 'Xiaomi 14 Ultra with Leica quad camera system and Snapdragon 8 Gen 3. Professional photography in your pocket.'),

-- Laptops
('p2222221-2222-2222-2222-222222222222', 'macbook-pro-16-m3-max', 'MacBook Pro 16" M3 Max 36GB/1TB', 'Ultimate MacBook Pro with M3 Max chip, 16-inch Liquid Retina XDR display. Perfect for professionals and creators.', 389999, 409999, 295000, '33333333-3333-3333-3333-333333333333', '11111111-1111-1111-1111-111111111111', 'APL-MBP16-M3MAX', '195949038051', 15, 5, '["https://cdn.xarastore.com/products/macbook-pro-16-1.jpg", "https://cdn.xarastore.com/products/macbook-pro-16-2.jpg", "https://cdn.xarastore.com/products/macbook-pro-16-3.jpg"]', true, true, 4.9, 94, '["laptop", "apple", "macbook", "m3-max", "professional"]', 'MacBook Pro 16" M3 Max - Premium Performance | Xarastore', 'Get the powerful MacBook Pro 16" with M3 Max chip. Perfect for video editing, 3D rendering, and professional work.'),

('p2222222-2222-2222-2222-222222222222', 'dell-xps-15-i9-rtx4060', 'Dell XPS 15 (2024) - i9, RTX 4060, 32GB', 'Premium Windows laptop with Intel Core i9, NVIDIA RTX 4060, and stunning 15.6" OLED display. Built for creators and professionals.', 284999, 299999, 215000, '33333333-3333-3333-3333-333333333333', '55555555-5555-5555-5555-555555555555', 'DEL-XPS15-I9', '884116438847', 22, 5, '["https://cdn.xarastore.com/products/dell-xps-15-1.jpg", "https://cdn.xarastore.com/products/dell-xps-15-2.jpg"]', true, true, 4.7, 78, '["laptop", "dell", "xps", "gaming", "creator"]', 'Dell XPS 15 i9 RTX 4060 - Creator Laptop | Xarastore', 'Dell XPS 15 with Core i9, RTX 4060 graphics, and OLED display. Perfect for content creation and gaming.'),

('p2222223-2222-2222-2222-222222222222', 'hp-spectre-x360-14', 'HP Spectre x360 14" - i7, 16GB, 1TB SSD', 'Premium 2-in-1 convertible laptop with 13.5" 3K2K OLED touchscreen. Elegant design with powerful performance.', 164999, 174999, 125000, '33333333-3333-3333-3333-333333333333', '44444444-4444-4444-4444-444444444444', 'HP-SPX360-14', '196068364953', 18, 5, '["https://cdn.xarastore.com/products/hp-spectre-1.jpg", "https://cdn.xarastore.com/products/hp-spectre-2.jpg"]', true, false, 4.6, 56, '["laptop", "hp", "2-in-1", "convertible", "touchscreen"]', 'HP Spectre x360 14" - Premium 2-in-1 Laptop | Xarastore', 'HP Spectre x360 with OLED touchscreen and Core i7 processor. Versatile 2-in-1 design for work and creativity.'),

('p2222224-2222-2222-2222-222222222222', 'lenovo-thinkpad-x1-carbon-gen-11', 'Lenovo ThinkPad X1 Carbon Gen 11 - i7, 32GB', 'Business ultrabook with legendary keyboard, 14" 2.8K OLED display, and military-grade durability. Weighs only 1.12kg.', 214999, 229999, 165000, '33333333-3333-3333-3333-333333333333', 'd1111111-1111-1111-1111-111111111111', 'LEN-X1C-G11', '197530874932', 25, 5, '["https://cdn.xarastore.com/products/thinkpad-x1-1.jpg", "https://cdn.xarastore.com/products/thinkpad-x1-2.jpg"]', true, true, 4.8, 112, '["laptop", "lenovo", "thinkpad", "business", "ultrabook"]', 'Lenovo ThinkPad X1 Carbon Gen 11 - Business Laptop | Xarastore', 'ThinkPad X1 Carbon Gen 11 with Core i7 and OLED display. Premium business laptop with legendary durability.'),

-- Audio
('p3333331-3333-3333-3333-333333333333', 'sony-wh-1000xm5', 'Sony WH-1000XM5 Wireless Headphones', 'Industry-leading noise cancellation with premium sound quality. 30-hour battery life and multi-point connectivity.', 44999, 49999, 32000, '44444444-4444-4444-4444-444444444444', '33333333-3333-3333-3333-333333333333', 'SON-WH1000XM5', '4548736141155', 85, 15, '["https://cdn.xarastore.com/products/sony-wh1000xm5-1.jpg", "https://cdn.xarastore.com/products/sony-wh1000xm5-2.jpg", "https://cdn.xarastore.com/products/sony-wh1000xm5-3.jpg"]', true, true, 4.8, 342, '["headphones", "sony", "noise-cancelling", "wireless", "premium"]', 'Sony WH-1000XM5 - Best Noise Cancelling Headphones | Xarastore', 'Sony WH-1000XM5 with industry-leading noise cancellation. Premium wireless headphones with 30-hour battery life.'),

('p3333332-3333-3333-3333-333333333333', 'airpods-pro-2nd-gen-usbc', 'Apple AirPods Pro (2nd Gen) USB-C', 'Active Noise Cancellation, Adaptive Audio, and Personalized Spatial Audio. Now with USB-C charging case.', 34999, 37999, 26000, '44444444-4444-4444-4444-444444444444', '11111111-1111-1111-1111-111111111111', 'APL-APP2-USBC', '195949048739', 120, 20, '["https://cdn.xarastore.com/products/airpods-pro-2-1.jpg", "https://cdn.xarastore.com/products/airpods-pro-2-2.jpg"]', true, true, 4.7, 289, '["earbuds", "apple", "airpods", "noise-cancelling", "wireless"]', 'AirPods Pro 2nd Gen USB-C - Apple | Xarastore', 'AirPods Pro (2nd generation) with USB-C. Active Noise Cancellation and Adaptive Audio for the perfect fit.'),

('p3333333-3333-3333-3333-333333333333', 'bose-quietcomfort-ultra', 'Bose QuietComfort Ultra Headphones', 'Legendary noise cancellation meets breakthrough spatialized audio. Premium comfort for all-day listening.', 49999, 54999, 37000, '44444444-4444-4444-4444-444444444444', 'd2222222-2222-2222-2222-222222222222', 'BOS-QCULT', '017817845991', 42, 10, '["https://cdn.xarastore.com/products/bose-qc-ultra-1.jpg", "https://cdn.xarastore.com/products/bose-qc-ultra-2.jpg"]', true, true, 4.7, 156, '["headphones", "bose", "noise-cancelling", "premium", "spatial-audio"]', 'Bose QuietComfort Ultra - Premium Headphones | Xarastore', 'Bose QuietComfort Ultra with world-class noise cancellation and immersive spatial audio. Premium comfort guaranteed.'),

('p3333334-3333-3333-3333-333333333333', 'jbl-flip-6-bluetooth-speaker', 'JBL Flip 6 Portable Bluetooth Speaker', 'Powerful sound with deep bass, IP67 waterproof rating, and 12 hours of playtime. Perfect for outdoor adventures.', 14999, 16999, 11000, '44444444-4444-4444-4444-444444444444', 'd3333333-3333-3333-3333-333333333333', 'JBL-FLIP6', '050036385596', 95, 20, '["https://cdn.xarastore.com/products/jbl-flip-6-1.jpg", "https://cdn.xarastore.com/products/jbl-flip-6-2.jpg"]', true, false, 4.6, 234, '["speaker", "jbl", "bluetooth", "waterproof", "portable"]', 'JBL Flip 6 Bluetooth Speaker - Waterproof | Xarastore', 'JBL Flip 6 portable speaker with powerful bass and IP67 waterproof rating. 12 hours of playtime for outdoor fun.'),

