-- Men's Fashion
('p4444441-4444-4444-4444-444444444444', 'nike-air-max-90', 'Nike Air Max 90 - Black/White', 'Iconic Nike Air Max 90 with visible Air cushioning and classic design. Premium leather and mesh upper for comfort and style.', 14999, 17999, 11000, '66666666-6666-6666-6666-666666666666', '66666666-6666-6666-6666-666666666666', 'NIK-AM90-BW', '196604443241', 68, 15, '["https://cdn.xarastore.com/products/nike-air-max-90-1.jpg", "https://cdn.xarastore.com/products/nike-air-max-90-2.jpg", "https://cdn.xarastore.com/products/nike-air-max-90-3.jpg"]', true, true, 4.7, 189, '["shoes", "nike", "sneakers", "air-max", "mens"]', 'Nike Air Max 90 Black/White - Iconic Sneakers | Xarastore', 'Classic Nike Air Max 90 in Black/White colorway. Visible Air cushioning and premium materials for all-day comfort.'),

('p4444442-4444-4444-4444-444444444444', 'adidas-ultraboost-22', 'Adidas Ultraboost 22 Running Shoes', 'Revolutionary running shoes with Boost cushioning and Primeknit upper. Designed for comfort and performance on every run.', 18999, 21999, 14000, '66666666-6666-6666-6666-666666666666', '77777777-7777-7777-7777-777777777777', 'ADI-UB22', '4066759318557', 54, 15, '["https://cdn.xarastore.com/products/ultraboost-22-1.jpg", "https://cdn.xarastore.com/products/ultraboost-22-2.jpg"]', true, true, 4.8, 267, '["shoes", "adidas", "running", "ultraboost", "mens"]', 'Adidas Ultraboost 22 - Premium Running Shoes | Xarastore', 'Adidas Ultraboost 22 with responsive Boost cushioning. Perfect for runners seeking comfort and performance.'),

('p4444443-4444-4444-4444-444444444444', 'levis-501-original-jeans', 'Levi''s 501 Original Fit Jeans - Dark Blue', 'The original jean since 1873. Classic straight fit with button fly, crafted from 100% cotton denim for authentic style.', 7999, 9999, 5500, '66666666-6666-6666-6666-666666666666', 'd4444444-4444-4444-4444-444444444444', 'LEV-501-DB', '5400598471141', 145, 25, '["https://cdn.xarastore.com/products/levis-501-1.jpg", "https://cdn.xarastore.com/products/levis-501-2.jpg"]', true, false, 4.6, 423, '["jeans", "levis", "denim", "mens", "classic"]', 'Levi''s 501 Original Fit Jeans - Dark Blue | Xarastore', 'Classic Levi''s 501 jeans in dark blue. The original jean with straight fit and timeless style since 1873.'),

('p4444444-4444-4444-4444-444444444444', 'hugo-boss-slim-fit-shirt', 'Hugo Boss Slim Fit Business Shirt - White', 'Premium cotton business shirt with modern slim fit. Perfect for professional settings with sophisticated Hugo Boss styling.', 12999, 15999, 9500, '66666666-6666-6666-6666-666666666666', '99999999-9999-9999-9999-999999999999', 'HGB-SFS-WH', '4063538166750', 72, 15, '["https://cdn.xarastore.com/products/boss-shirt-1.jpg", "https://cdn.xarastore.com/products/boss-shirt-2.jpg"]', true, false, 4.5, 98, '["shirt", "hugo-boss", "business", "mens", "formal"]', 'Hugo Boss Slim Fit Shirt White - Business | Xarastore', 'Premium Hugo Boss business shirt with slim fit. Perfect for professional style with premium cotton fabric.'),

