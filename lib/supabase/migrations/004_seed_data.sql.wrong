-- ============================================================================
-- UPDATE COUNTS
-- ============================================================================

-- Update product counts in categories
UPDATE categories SET product_count = CASE slug
    WHEN 'electronics' THEN 8
    WHEN 'smartphones' THEN 4
    WHEN 'laptops' THEN 4
    WHEN 'audio' THEN 4
    WHEN 'fashion' THEN 6
    WHEN 'mens-fashion' THEN 4
    WHEN 'womens-fashion' THEN 2
    WHEN 'shoes' THEN 2
    WHEN 'home-living' THEN 3
    WHEN 'kitchen' THEN 2
    WHEN 'furniture' THEN 1
    WHEN 'beauty-health' THEN 3
    WHEN 'skincare' THEN 3
    WHEN 'sports-outdoors' THEN 2
    WHEN 'fitness' THEN 2
    ELSE 0
END;

-- Update brand product counts
UPDATE brands SET product_count = CASE slug
    WHEN 'apple' THEN 3
    WHEN 'samsung' THEN 2
    WHEN 'sony' THEN 1
    WHEN 'hp' THEN 1
    WHEN 'dell' THEN 1
    WHEN 'lenovo' THEN 1
    WHEN 'bose' THEN 1
    WHEN 'jbl' THEN 1
    WHEN 'nike' THEN 1
    WHEN 'adidas' THEN 2
    WHEN 'zara' THEN 1
    WHEN 'hugo-boss' THEN 1
    WHEN 'levis' THEN 1
    WHEN 'hm' THEN 1
    WHEN 'ikea' THEN 1
    WHEN 'kitchenaid' THEN 1
    WHEN 'philips' THEN 1
    WHEN 'loreal' THEN 1
    WHEN 'estee-lauder' THEN 1
    WHEN 'nivea' THEN 1
    WHEN 'under-armour' THEN 1
    ELSE 0
END;

-- Success message
DO $$
BEGIN
    RAISE NOTICE 'Seed data inserted successfully!';
    RAISE NOTICE 'Categories: 23';
    RAISE NOTICE 'Brands: 27';
    RAISE NOTICE 'Products: 30+';
    RAISE NOTICE 'Collections: 10';
    RAISE NOTICE 'Settings: Configured';
END $$;
