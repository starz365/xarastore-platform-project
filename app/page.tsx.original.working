function ProductGridSkeleton() {
  return (
    <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      {Array.from({ length: 8 }).map((_, i) => (
        <Skeleton key={i} className="h-64" />
      ))}
    </div>
  );
}

const categories = [
  { slug: 'electronics', name: 'Electronics', count: 1240, icon: '📱' },
  { slug: 'fashion', name: 'Fashion', count: 856, icon: '👕' },
  { slug: 'home-garden', name: 'Home & Garden', count: 720, icon: '🏠' },
  { slug: 'beauty', name: 'Beauty', count: 430, icon: '💄' },
  { slug: 'sports', name: 'Sports', count: 310, icon: '⚽' },
  { slug: 'automotive', name: 'Automotive', count: 280, icon: '🚗' },
];
