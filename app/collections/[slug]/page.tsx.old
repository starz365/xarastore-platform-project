import { notFound } from 'next/navigation';
import { Suspense } from 'react';
import { Sparkles, Clock, Tag, TrendingUp, Shield, Truck } from 'lucide-react';
import { ProductGrid } from '@/components/product/ProductGrid';
import { DealTimer } from '@/components/deals/DealTimer';
import { Button } from '@/components/ui/Button';
import { Skeleton } from '@/components/ui/Skeleton';
import { searchProducts } from '@/lib/supabase/queries/products';

interface CollectionPageProps {
  params: Promise<{ slug: string }>;
  searchParams: Promise<{ [key: string]: string | string[] | undefined }>;
}

// Mock collections data - in production, this would come from Supabase
const collections = [
  {
    slug: 'summer-sale',
    name: 'Summer Sale',
    description: 'Beat the heat with amazing discounts on summer essentials',
    image: '/collections/summer.jpg',
    products: 156,
    endDate: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000), // 7 days from now
    badge: '🔥 Hot Deal',
  },
  {
    slug: 'back-to-school',
    name: 'Back to School',
    description: 'Everything students need for the new academic year',
    image: '/collections/school.jpg',
    products: 89,
    endDate: new Date(Date.now() + 14 * 24 * 60 * 60 * 1000),
    badge: '🎓 Essential',
  },
  {
    slug: 'tech-fest',
    name: 'Tech Fest',
    description: 'Latest gadgets and electronics at unbeatable prices',
    image: '/collections/tech.jpg',
    products: 234,
    endDate: new Date(Date.now() + 5 * 24 * 60 * 60 * 1000),
    badge: '💻 Limited Time',
  },
  {
    slug: 'home-essentials',
    name: 'Home Essentials',
    description: 'Upgrade your living space with premium home goods',
    image: '/collections/home.jpg',
    products: 178,
    endDate: null,
    badge: '🏠 Popular',
  },
];

export async function generateMetadata({ params }: CollectionPageProps) {
  const { slug } = await params;
  const collection = collections.find(c => c.slug === slug);

  if (!collection) {
    return {
      title: 'Collection Not Found | Xarastore',
      description: 'Collection not found',
    };
  }

  return {
    title: `${collection.name} Collection | Xarastore`,
    description: collection.description,
  };
}

export default async function CollectionPage({ params, searchParams }: CollectionPageProps) {
  const { slug } = await params;
  const paramsObj = await searchParams;
  
  const collection = collections.find(c => c.slug === slug);

  if (!collection) {
    notFound();
  }

  const page = typeof paramsObj.page === 'string' ? parseInt(paramsObj.page) : 1;
  const sort = typeof paramsObj.sort === 'string' ? paramsObj.sort : 'popular';
  
  // In production, this would query products specifically for this collection
  const { products, total } = await searchProducts(
    '',
    { sortBy: sort },
    page,
    24
  );

  // Filter for collection-specific products (mock logic)
  const collectionProducts = products.slice(0, Math.min(products.length, collection.products));

  const features = [
    { icon: Shield, title: 'Quality Guaranteed', description: 'All items verified' },
    { icon: Truck, title: 'Free Delivery', description: 'Over KES 2,000' },
    { icon: Tag, title: 'Best Price', description: 'Price match guarantee' },
    { icon: Sparkles, title: 'Exclusive Items', description: 'Collection exclusive' },
  ];

  const trendingItems = collectionProducts.slice(0, 4);
  const bestDeals = collectionProducts.filter(p => p.originalPrice).slice(0, 4);

  return (
    <div className="min-h-screen bg-gradient-to-b from-gray-50 to-white">
      {/* Collection Hero */}
      <div className="relative overflow-hidden bg-gradient-to-r from-red-600 to-red-800 text-white">
        <div className="absolute inset-0 bg-black/20" />
        <div className="container-responsive relative py-16 md:py-24">
          <div className="max-w-3xl">
            {/* Collection Badge */}
            <div className="inline-flex items-center space-x-2 bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 mb-6">
              <Sparkles className="w-4 h-4" />
              <span className="text-sm font-medium">{collection.badge}</span>
            </div>
            
            <h1 className="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
              {collection.name}
            </h1>
            
            <p className="text-xl opacity-90 mb-8 max-w-2xl">
              {collection.description}
            </p>
            
            <div className="flex flex-wrap items-center gap-6">
              <div className="flex items-center space-x-4">
                <div className="text-center">
                  <div className="text-3xl font-bold">{collection.products}+</div>
                  <div className="text-sm opacity-80">Products</div>
                </div>
                <div className="h-8 w-px bg-white/30" />
                <div className="text-center">
                  <div className="text-3xl font-bold">Up to 70%</div>
                  <div className="text-sm opacity-80">Off</div>
                </div>
              </div>
              
              {collection.endDate && (
                <div className="flex items-center space-x-4">
                  <div className="h-8 w-px bg-white/30" />
                  <div className="flex items-center space-x-3">
                    <Clock className="w-5 h-5" />
                    <div>
                      <div className="text-sm opacity-80">Ends in</div>
                      <DealTimer targetTime={collection.endDate} />
                    </div>
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>

      <div className="container-responsive py-8">
        {/* Collection Features */}
        <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
          {features.map((feature, index) => {
            const Icon = feature.icon;
            return (
              <div key={index} className="bg-white rounded-xl border border-gray-200 p-4 text-center">
                <div className="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-3">
                  <Icon className="w-5 h-5 text-red-600" />
                </div>
                <h3 className="font-semibold text-sm mb-1">{feature.title}</h3>
                <p className="text-xs text-gray-600">{feature.description}</p>
              </div>
            );
          })}
        </div>

        {/* Trending Now */}
        {trendingItems.length > 0 && (
          <div className="mb-12">
            <div className="flex items-center justify-between mb-8">
              <div className="flex items-center space-x-3">
                <div className="p-2 bg-red-100 rounded-lg">
                  <TrendingUp className="w-6 h-6 text-red-600" />
                </div>
                <div>
                  <h2 className="text-2xl md:text-3xl font-bold">🔥 Trending Now</h2>
                  <p className="text-gray-600">Most popular in this collection</p>
                </div>
              </div>
              <Button variant="link" href={`/collections/${slug}?sort=popular`}>
                View All Trending
              </Button>
            </div>
            <Suspense fallback={<ProductGridSkeleton count={4} />}>
              <ProductGrid products={trendingItems} />
            </Suspense>
          </div>
        )}

        {/* Best Deals */}
        {bestDeals.length > 0 && (
          <div className="mb-12">
            <div className="flex items-center justify-between mb-8">
              <div className="flex items-center space-x-3">
                <div className="p-2 bg-red-100 rounded-lg">
                  <Tag className="w-6 h-6 text-red-600" />
                </div>
                <div>
                  <h2 className="text-2xl md:text-3xl font-bold">💰 Best Deals</h2>
                  <p className="text-gray-600">Biggest discounts in this collection</p>
                </div>
              </div>
              <Button variant="link" href={`/collections/${slug}?sort=price-low`}>
                View All Deals
              </Button>
            </div>
            <Suspense fallback={<ProductGridSkeleton count={4} />}>
              <ProductGrid products={bestDeals} showTimer={!!collection.endDate} />
            </Suspense>
          </div>
        )}

        {/* All Collection Products */}
        <div className="mb-12">
          <div className="flex items-center justify-between mb-8">
            <div>
              <h2 className="text-2xl md:text-3xl font-bold">All Collection Items</h2>
              <p className="text-gray-600 mt-2">
                {collectionProducts.length} products available
              </p>
            </div>
            
            <div className="flex items-center space-x-4">
              <select
                defaultValue={sort}
                className="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:border-red-600 focus:ring-2 focus:ring-red-600/20 outline-none"
              >
                <option value="popular">Most Popular</option>
                <option value="newest">Newest First</option>
                <option value="price-low">Price: Low to High</option>
                <option value="price-high">Price: High to Low</option>
                <option value="rating">Top Rated</option>
              </select>
            </div>
          </div>

          {collectionProducts.length > 0 ? (
            <>
              <Suspense fallback={<ProductGridSkeleton />}>
                <ProductGrid products={collectionProducts} />
              </Suspense>

              {/* Pagination */}
              {collection.products > 24 && (
                <div className="mt-12 flex justify-center">
                  <nav className="flex items-center space-x-2">
                    <Button
                      variant="outline"
                      size="sm"
                      disabled={page <= 1}
                      href={`/collections/${slug}?page=${page - 1}`}
                    >
                      Previous
                    </Button>
                    
                    {Array.from({ length: Math.min(5, Math.ceil(collection.products / 24)) }).map((_, i) => {
                      const pageNum = i + 1;
                      return (
                        <Button
                          key={pageNum}
                          variant={page === pageNum ? 'primary' : 'outline'}
                          size="sm"
                          href={`/collections/${slug}?page=${pageNum}`}
                        >
                          {pageNum}
                        </Button>
                      );
                    })}
                    
                    {Math.ceil(collection.products / 24) > 5 && (
                      <>
                        <span className="px-2">...</span>
                        <Button
                          variant="outline"
                          size="sm"
                          href={`/collections/${slug}?page=${Math.ceil(collection.products / 24)}`}
                        >
                          {Math.ceil(collection.products / 24)}
                        </Button>
                      </>
                    )}
                    
                    <Button
                      variant="outline"
                      size="sm"
                      disabled={page * 24 >= collection.products}
                      href={`/collections/${slug}?page=${page + 1}`}
                    >
                      Next
                    </Button>
                  </nav>
                </div>
              )}
            </>
          ) : (
            <div className="bg-white rounded-xl shadow-sm border border-gray-200 p-12 text-center">
              <div className="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
                <Sparkles className="w-12 h-12 text-gray-400" />
              </div>
              <h3 className="text-xl font-semibold text-gray-900 mb-3">
                Collection Coming Soon
              </h3>
              <p className="text-gray-600 mb-8 max-w-md mx-auto">
                This collection is being curated. Check back soon for amazing products!
              </p>
              <Button variant="primary" asChild>
                <a href="/collections">
                  Browse Other Collections
                </a>
              </Button>
            </div>
          )}
        </div>

        {/* Collection Benefits */}
        <div className="bg-gradient-to-r from-red-600 to-red-800 text-white rounded-2xl p-8 mb-12">
          <h2 className="text-3xl font-bold mb-6">Why This Collection?</h2>
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <div>
              <div className="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center mb-4">
                <span className="text-2xl">🎯</span>
              </div>
              <h3 className="font-semibold text-lg mb-2">Curated Selection</h3>
              <p className="opacity-90">
                Handpicked items that meet our quality standards and customer preferences
              </p>
            </div>
            <div>
              <div className="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center mb-4">
                <span className="text-2xl">💰</span>
              </div>
              <h3 className="font-semibold text-lg mb-2">Exclusive Pricing</h3>
              <p className="opacity-90">
                Special collection-only discounts and bundle offers
              </p>
            </div>
            <div>
              <div className="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center mb-4">
                <span className="text-2xl">⚡</span>
              </div>
              <h3 className="font-semibold text-lg mb-2">Priority Shipping</h3>
              <p className="opacity-90">
                Faster processing and delivery for collection items
              </p>
            </div>
          </div>
        </div>

        {/* Other Collections */}
        <div>
          <h2 className="text-2xl md:text-3xl font-bold mb-8">More Collections</h2>
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {collections
              .filter(c => c.slug !== slug)
              .slice(0, 4)
              .map((otherCollection) => (
                <a
                  key={otherCollection.slug}
                  href={`/collections/${otherCollection.slug}`}
                  className="group"
                >
                  <div className="bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow">
                    <div className="aspect-video bg-gradient-to-br from-red-100 to-red-200 relative overflow-hidden">
                      <div className="absolute inset-0 flex items-center justify-center">
                        <Sparkles className="w-12 h-12 text-red-600 opacity-20" />
                      </div>
                      <div className="absolute bottom-4 left-4">
                        <span className="px-3 py-1 bg-white/90 backdrop-blur-sm text-red-600 text-sm font-medium rounded-full">
                          {otherCollection.badge}
                        </span>
                      </div>
                    </div>
                    <div className="p-6">
                      <h3 className="font-bold text-lg mb-2 group-hover:text-red-600 transition-colors">
                        {otherCollection.name}
                      </h3>
                      <p className="text-gray-600 text-sm mb-4">
                        {otherCollection.products} products
                      </p>
                      <Button variant="link" className="p-0 h-auto text-red-600">
                        Explore Collection →
                      </Button>
                    </div>
                  </div>
                </a>
              ))}
          </div>
        </div>
      </div>
    </div>
  );
}

function ProductGridSkeleton({ count = 8 }: { count?: number }) {
  return (
    <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      {Array.from({ length: count }).map((_, i) => (
        <Skeleton key={i} className="h-64 rounded-xl" />
      ))}
    </div>
  );
}
